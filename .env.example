# Camporee Conductor — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
#
# Variables marked [docker-compose] are set per-container in docker-compose.yml
# and do NOT need to be in .env — listed here for documentation only.

# ---------------------------------------------------------------------------
# CLERK — Authentication (Composer + cloud Collator)
# Obtain from: https://dashboard.clerk.com → API Keys
# Required for Composer. Required for Collator when COLLATOR_MODE=cloud.
# ---------------------------------------------------------------------------
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ---------------------------------------------------------------------------
# GEMINI — AI game generation (Composer only)
# Obtain from: https://aistudio.google.com/app/apikey
# ---------------------------------------------------------------------------
GEMINI_API_KEY=AIzaSy...

# ---------------------------------------------------------------------------
# SESSION SECRET — express-session (Collator offline mode)
# Any long random string. Generate with: openssl rand -hex 32
# Required in production; defaults to an insecure hardcoded value if omitted.
# ---------------------------------------------------------------------------
SESSION_SECRET=replace-with-openssl-rand-hex-32

# ---------------------------------------------------------------------------
# COLLATOR MODE — controls auth strategy for the Collator
# Values: offline (default) | cloud
#   offline = email honor system, express-session, no Clerk required
#   cloud   = Clerk JWT, event_permissions table, requires Clerk keys above
# ---------------------------------------------------------------------------
COLLATOR_MODE=offline

# ---------------------------------------------------------------------------
# NODE_ENV — runtime environment
# Values: development | production | test
# Set to "production" on VPS. CI sets "test" automatically via Vitest.
# ---------------------------------------------------------------------------
NODE_ENV=development

# ---------------------------------------------------------------------------
# [docker-compose] PATH OVERRIDES — set per-container, not in .env
# Documented here for reference. Override in docker-compose.yml environment: block.
# ---------------------------------------------------------------------------
# PORT=3000                                     # Collator: 3000, Composer: 3001
# ACTIVE_SERVICES=collator                      # Collator container
# ACTIVE_SERVICES=curator,composer              # Composer container
# EVENT_PATH=/app/data/active-event             # Collator: unpacked cartridge
# WORKSPACE_PATH=/app/data/workspaces          # Composer: event design workspaces
# LIBRARY_PATH=/app/data/library               # Both: game template library
# CONDUCTOR_DB_PATH=/app/data/shared/conductor.db  # Both: SQLite AAA database
