# Dependencies
node_modules/
.pnpm-store/

# Production Database & Data
# We want the 'data' folder to exist, but NOT the actual DB files inside it.
data/*
!data/.gitkeep
*.sqlite
*.db
*.sqlite3
*.log
*.xlsx
scratch/
SCHEMA.md

scripts/demo/score-p*

# Environment Variables (Secrets)
.env
.env.local

# TLS Certificates (never commit private keys)
certs/*.pem
certs/*.crt
certs/*.key

# OS Generated Files
.DS_Store
Thumbs.db

# Editor Directories
.vscode/
.idea/

# Docker (Optional: if you have local override files)
docker-compose.override.yml
camporee/active/

# generated scripts for filling data
scripts/demo/score-*.cjs

# Playwright Test Generated Files
playwright-report/
test-results/

# Personal context files (not part of the codebase)
JIM.md
JIM_v2.md

# Claude Code local settings and memory
.claude/

# Binary packages and downloaded installers
*.deb
*.rpm
*.exe
*.pkg

# Source PDFs (content already incorporated into game JSON)
*.pdf
