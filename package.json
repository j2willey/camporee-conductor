{
  "name": "camporee-conductor",
  "version": "1.0.0",
  "description": "Offline-first event management system for BSA Camporee skill competitions — Composer, Collator, and Judge PWA in a portable cartridge workflow",
  "type": "module",
  "main": "server.js",
  "author": "Jim Willey",
  "license": "MIT",
  "homepage": "https://camporeeconductor.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/j2willey/camporee-conductor.git"
  },
  "keywords": [
    "bsa",
    "scouts",
    "camporee",
    "event-management",
    "scoring",
    "pwa",
    "offline-first"
  ],
  "scripts": {
    "start": "node server.js",
    "dev:all": "ACTIVE_SERVICES=curator,composer,collator node server.js",
    "dev:collator": "ACTIVE_SERVICES=collator node server.js",
    "minify": "terser public/js/apps/composer.js -o public/js/apps/composer.js --compress --mangle && terser public/js/apps/curator.js -o public/js/apps/curator.js --compress --mangle",
    "docs:schema": "node scripts/generate-docs.js",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "npx playwright test tests/e2e"
  },
  "dependencies": {
    "@clerk/express": "^2.1.22",
    "@google/genai": "^1.43.0",
    "adm-zip": "^0.5.16",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^9.0.0",
    "body-parser": "^1.20.2",
    "dotenv": "^17.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "multer": "^2.0.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "supertest": "^7.2.2",
    "supertest-fetch": "^2.0.0",
    "terser": "^5.19.2",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  }
}
