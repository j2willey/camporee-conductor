{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://localhost:3000/schemas/camporee-instance.json",
  "title": "Camporee Event Configuration (Manifest)",
  "type": "object",
  "required": [
    "schemaVersion",
    "meta",
    "leagues",
    "rosters",
    "playlist"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "meta": {
      "type": "object",
      "required": [
        "camporeeId",
        "title",
        "year",
        "theme"
      ],
      "properties": {
        "camporeeId": {
          "type": "string",
          "format": "uuid"
        },
        "title": {
          "type": "string"
        },
        "theme": {
          "type": "string"
        },
        "year": {
          "type": "integer"
        },
        "director": {
          "type": "string"
        },
        "district": {
          "type": "string"
        },
        "council": {
          "type": "string"
        },
        "location": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "dates": {
          "type": "object",
          "properties": {
            "start": { "type": "string" },
            "end": { "type": "string" }
          }
        },
        "contacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string" },
              "name": { "type": "string" },
              "email": { "type": "string" },
              "phone": { "type": "string" }
            }
          }
        },
        "introduction": {
          "type": "string"
        }
      }
    },
    "terminology": {
      "type": "object",
      "description": "Configurable display labels for participant tiers. UI still uses hardcoded BSA labels in Phase 1.",
      "properties": {
        "unit": { "type": ["string", "null"] },
        "subunit": { "type": ["string", "null"] },
        "member": { "type": ["string", "null"] },
        "event": { "type": ["string", "null"] },
        "organizer": { "type": ["string", "null"] }
      }
    },
    "leagues": {
      "type": "array",
      "description": "Director-defined scoring pools. Every game references a league by id.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "tier", "registration"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Primary key. Referenced by game.league."
          },
          "label": {
            "type": "string",
            "description": "Display name (e.g. 'Patrol Games')."
          },
          "tier": {
            "type": "string",
            "enum": ["unit", "subunit", "individual"],
            "description": "Which roster tier competes in this league."
          },
          "registration": {
            "type": "string",
            "enum": ["registered", "open"],
            "description": "registered = entrants from roster; open = judge enters names at station."
          },
          "divisions": {
            "type": "array",
            "description": "Phase 3 placeholder. Always empty array for now.",
            "items": {
              "type": "object",
              "required": ["id", "label"],
              "properties": {
                "id": { "type": "string" },
                "label": { "type": "string" }
              }
            }
          }
        },
        "additionalProperties": false
      }
    },
    "sessions": {
      "type": "array",
      "description": "Phase 2 placeholder. Named time slots for judge display grouping. Empty = flat game list.",
      "default": [],
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "start": { "type": "string" },
          "end": { "type": "string" }
        }
      }
    },
    "rosters": {
      "type": "object",
      "description": "All competing entities for the event. units = primary competitive entities, subunits = patrols/dens.",
      "required": ["units", "subunits", "individuals"],
      "properties": {
        "units": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" }
            }
          }
        },
        "subunits": {
          "type": ["array", "null"],
          "items": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" },
              "unit_id": { "type": ["integer", "null"] }
            }
          }
        },
        "individuals": {
          "type": "array",
          "description": "Phase 3 placeholder. Always empty array for now.",
          "items": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" },
              "subunit_id": { "type": ["integer", "null"] },
              "unit_id": { "type": ["integer", "null"] }
            }
          }
        }
      }
    },
    "type_defaults": {
      "type": "object",
      "description": "Defines which common preset fields are injected for each league at runtime. Keyed by league id (e.g. 'patrol-games', 'troop-challenges', 'exhibition').",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "prefix": { "type": "array", "items": { "type": "string" } },
          "suffix": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "officials": {
      "type": "array",
      "description": "Personnel who serve as official scorers or administrators for this event.",
      "default": [],
      "items": {
        "type": "object",
        "required": ["display_name", "email"],
        "properties": {
          "user_id": {
            "type": ["string", "null"],
            "description": "Clerk user_id. Null for officials who do not have a Conductor account."
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string",
            "enum": ["director", "official"],
            "description": "Event role. 'director' for the event owner; 'official' for all others."
          }
        },
        "additionalProperties": false
      }
    },
    "playlist": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "gameId",
          "order"
        ],
        "properties": {
          "gameId": {
            "type": "string",
            "description": "Must match a filename in the games/ folder (minus extension)"
          },
          "enabled": {
            "type": "boolean"
          },
          "order": {
            "type": "integer"
          }
        }
      }
    }
  }
}
