{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://localhost:3000/schemas/definitions/content.json",
    "title": "Game Content Narrative",
    "description": "Heavy narrative text and logistics for human consumption",
    "type": "object",
    "properties": {
        "legend": {
            "type": "string",
            "description": "Thematic setting/story"
        },
        "quest": {
            "type": "string",
            "description": "Primary objective"
        },
        "briefing": {
            "type": "string",
            "description": "Instructions for competitors"
        },
        "rules": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "scoring_overview": {
            "type": "string"
        },
        "judging_notes": {
            "type": "string"
        },
        "notes": {
            "type": "string"
        },
        "references": {
            "type": "string"
        },
        "marketing_image_url": {
            "type": "string",
            "format": "uri"
        },
        "logistics": {
            "type": "object",
            "properties": {
                "staffing": {
                    "type": "string"
                },
                "setup": {
                    "type": "string"
                },
                "reset": {
                    "type": "string"
                },
                "supplies_text": {
                    "type": "string",
                    "description": "Unstructured text representation of supplies needed"
                },
                "supplies": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": [
                            "item",
                            "qty"
                        ],
                        "properties": {
                            "item": {
                                "type": "string"
                            },
                            "qty": {
                                "type": "string"
                            },
                            "source": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    }
}