{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://localhost:3000/schemas/game.json",
    "title": "Game Definition",
    "description": "Defines a game concept. Can be used as a Library template (with variants) or an Active Camporee instance.",
    "type": "object",
    "required": [
        "library_uuid",
        "library_title",
        "type",
        "content",
        "scoring_model"
    ],
    "properties": {
        "library_uuid": {
            "type": "string",
            "anyOf": [
                {
                    "format": "uuid"
                },
                {
                    "maxLength": 0
                }
            ]
        },
        "library_title": {
            "type": "string",
            "description": "The original generic title of the game in the library"
        },
        "game_title": {
            "type": "string",
            "description": "The themed or display title for this specific game instance"
        },
        "id": {
            "type": "string",
            "description": "Short identifier (e.g., p10)"
        },
        "category": {
            "type": "string"
        },
        "type": {
            "type": "string",
            "enum": [
                "patrol",
                "troop",
                "exhibition"
            ]
        },
        "tags": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "content": {
            "$ref": "definitions/content.json",
            "description": "Generic content metadata for the unthemed game"
        },
        "scoring_model": {
            "$ref": "definitions/scoring.json"
        },
        "source_snapshot": {
            "type": "object",
            "properties": {
                "content": {
                    "$ref": "definitions/content.json"
                },
                "scoring_model": {
                    "$ref": "definitions/scoring.json"
                }
            }
        },
        "variants": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "library_uuid",
                    "title",
                    "content"
                ],
                "properties": {
                    "library_uuid": {
                        "type": "string",
                        "format": "uuid",
                        "description": "Unique ID for this variant version"
                    },
                    "title": {
                        "type": "string",
                        "description": "Name of the variant (e.g. 'Space Theme')"
                    },
                    "content": {
                        "$ref": "definitions/content.json"
                    },
                    "scoring_model": {
                        "$ref": "definitions/scoring.json"
                    }
                }
            }
        }
    }
}