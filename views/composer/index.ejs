    <% if (!testMode) { %>
    <!-- Clerk Auth Init — must come after composer.js so window.onload can be intercepted -->
    <script type="module">
        // Capture and replace the window.onload set by composer.js so we can gate it on auth
        const _composerLoad = window.onload;
        window.onload = null;

        async function bootstrap() {
            const signInEl = document.getElementById('clerk-sign-in');
            try {
                // With data-clerk-publishable-key, window.Clerk is the pre-initialized singleton.
                // We just need to call load() to activate it.
                if (!window.Clerk) throw new Error('Clerk SDK not available — check CDN URL and publishable key');
                await window.Clerk.load();

                if (window.Clerk.user) {
                    await showApp();
                } else {
                    showSignIn();
                }
            } catch (e) {
                console.error('[auth] Clerk init failed:', e);
                signInEl.innerHTML = `<div class="alert alert-danger small">
                    <strong>Auth error:</strong> ${e.message}<br>
                    <span class="text-muted">Check browser console and verify CLERK_PUBLISHABLE_KEY in .env</span>
                </div>`;
            }
        }

        async function showApp() {
            document.getElementById('auth-screen').style.display = 'none';
            document.getElementById('composer-nav').style.display = '';
            const layout = document.getElementById('composer-layout');
            layout.style.removeProperty('display');
            layout.classList.add('d-flex');

            const user = window.Clerk.user;
            const name = user.fullName || user.primaryEmailAddress?.emailAddress || '';
            const nameEl = document.getElementById('nav-user-display');
            if (name) { nameEl.textContent = name; nameEl.classList.remove('d-none'); }

            if (_composerLoad) _composerLoad.call(window);

            await checkProfileCompletion();
        }

        function showSignIn() {
            window.Clerk.mountSignIn(document.getElementById('clerk-sign-in'));
            window.Clerk.addListener(({ user }) => { if (user) location.reload(); });
        }

        async function checkProfileCompletion() {
            try {
                const token = await window.Clerk.session.getToken();
                const res = await fetch(window.API_BASE + '/api/me', {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if (!res.ok) return;
                const profile = await res.json();
                if (!profile.display_name) {
                    window.bootstrap.Modal.getOrCreateInstance(document.getElementById('profileModal')).show();
                }
            } catch (e) {
                console.warn('[auth] Profile check failed:', e);
            }
        }

        window.clerkSignOut = async function () {
            await window.Clerk.signOut();
            location.reload();
        };

        window.clerkSaveProfile = async function () {
            const errEl = document.getElementById('profileError');
            errEl.textContent = '';
            const display_name = document.getElementById('profileDisplayName').value.trim();
            if (!display_name) { errEl.textContent = 'Display name is required.'; return; }
            try {
                const token = await window.Clerk.session.getToken();
                const res = await fetch(window.API_BASE + '/api/me', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                    body: JSON.stringify({
                        display_name,
                        council_name: document.getElementById('profileCouncil').value.trim(),
                        district:     document.getElementById('profileDistrict').value.trim(),
                        primary_role: document.getElementById('profileRole').value,
                        years_in_scouting: parseInt(document.getElementById('profileYears').value) || null
                    })
                });
                if (res.ok) {
                    window.bootstrap.Modal.getInstance(document.getElementById('profileModal')).hide();
                } else {
                    errEl.textContent = 'Save failed. Please try again.';
                }
            } catch (e) {
                errEl.textContent = 'Save failed. Please try again.';
            }
        };

        window.addEventListener('load', bootstrap);
    </script>
    <% } %>

