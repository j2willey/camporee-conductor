<!DOCTYPE html>
<html lang="en">

<head>
    <script>window.API_BASE = "/composer";</script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>

    <link rel="stylesheet" href="/css/bootstrap.min.css">

    <!-- Firebase SDKs -->
    <link rel="stylesheet" href="/css/conductor.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">
                <i class="fas fa-campground"></i> Camporee Composer
            </a>

            <div class="d-flex align-items-center">
                <button class="btn btn-outline-light btn-sm me-2" onclick="composer.newCamporee()">
                    <i class="fas fa-file"></i> New
                </button>
                <button class="btn btn-outline-info btn-sm me-2" onclick="composer.promptLoadWorkspace()">
                    <i class="fas fa-server"></i> Load Workspace
                </button>
                <label class="btn btn-outline-warning btn-sm me-2 mb-0">
                    <i class="fas fa-folder-open"></i> Import Zip
                    <input type="file" id="fileInput" accept=".zip" hidden>
                </label>
                <button class="btn btn-success btn-sm" onclick="composer.exportCamporee()">
                    <i class="fas fa-save"></i> Export Zip
                </button>
            </div>
        </div>
    </nav>

    <div id="composer-layout" class="d-flex w-100">
        <!-- Sidebar Navigation -->
        <aside id="composer-sidebar" class="bg-light d-flex flex-column h-100" style="width: 320px; flex-shrink: 0;">
            <div class="p-3 border-bottom bg-white">
                <h5 class="mb-0 fw-bold">Camporee Instance</h5>
            </div>
            <div class="flex-grow-1 overflow-auto p-2" id="navAccordion">

                <button class="btn btn-light w-100 text-start fw-bold p-2 mb-1 nav-pane-btn active" id="btn-meta"
                    onclick="composer.showPane('meta-pane', this)">
                    <i class="fas fa-info-circle fa-fw text-primary me-2"></i> Camporee Info
                </button>



                <!-- Patrol Games -->
                <div class="accordion-item bg-transparent border-0 mb-1">
                    <button
                        class="btn btn-light w-100 text-start fw-bold p-2 nav-pane-btn d-flex align-items-center justify-content-between"
                        type="button" data-bs-toggle="collapse" data-bs-target="#collapsePatrol" id="btn-patrol">
                        <span><i class="fas fa-users fa-fw text-primary me-2"></i> Patrol Games</span>
                        <span class="badge bg-secondary rounded-pill" id="patrolCount">0</span>
                    </button>
                    <div id="collapsePatrol" class="collapse show">
                        <div class="p-2 pb-0 pt-1">
                            <div class="d-flex gap-1 mb-2">
                                <button class="btn btn-sm btn-primary flex-grow-1" onclick="composer.addGame('patrol')"
                                    title="New Patrol Game"><i class="fas fa-plus"></i></button>
                                <button class="btn btn-sm btn-outline-primary flex-grow-1"
                                    onclick="window.bootstrap.Modal.getOrCreateInstance(document.getElementById('libraryModal')).show()"
                                    title="Import from Library"><i class="fas fa-file-import"></i></button>
                            </div>
                            <div id="patrolList" class="list-group list-group-flush small rounded border bg-white">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Troop Events -->
                <div class="accordion-item bg-transparent border-0 mb-1">
                    <button
                        class="btn btn-light w-100 text-start fw-bold p-2 nav-pane-btn d-flex align-items-center justify-content-between"
                        type="button" data-bs-toggle="collapse" data-bs-target="#collapseTroop" id="btn-troop">
                        <span><i class="fas fa-campground fa-fw text-primary me-2"></i> Troop Events</span>
                        <span class="badge bg-secondary rounded-pill" id="troopCount">0</span>
                    </button>
                    <div id="collapseTroop" class="collapse show">
                        <div class="p-2 pb-0 pt-1">
                            <div class="d-flex gap-1 mb-2">
                                <button class="btn btn-sm btn-success flex-grow-1" onclick="composer.addGame('troop')"
                                    title="New Troop Event"><i class="fas fa-plus"></i></button>
                                <button class="btn btn-sm btn-outline-success flex-grow-1"
                                    onclick="window.bootstrap.Modal.getOrCreateInstance(document.getElementById('libraryModal')).show()"
                                    title="Import from Library"><i class="fas fa-file-import"></i></button>
                            </div>
                            <div id="troopList" class="list-group list-group-flush small rounded border bg-white"></div>
                        </div>
                    </div>
                </div>

                <div class="mt-3">
                    <button class="btn btn-light w-100 text-start fw-bold p-2 nav-pane-btn" id="btn-presets"
                        onclick="composer.showPane('presets-pane', this)">
                        <i class="fas fa-sliders-h fa-fw text-primary me-2"></i> Scoring Presets
                    </button>
                </div>

            </div>
        </aside>

        <!-- Resizer Handle -->
        <div id="sidebar-resizer" class="sidebar-resizer"></div>

        <!-- Main Content -->
        <main id="composer-main-pane" class="flex-grow-1 bg-white p-4 h-100 overflow-auto">

            <div id="welcome-pane" class="text-center text-muted mt-5 d-none editor-pane">
                <h2><i class="fas fa-campground mb-3 fa-2x"></i></h2>
                <h4>Select an item from the left</h4>
            </div>

            <!-- Meta Pane -->
            <div id="meta-pane" class="editor-pane">
                <h4>Event Details</h4>
                <p class="text-muted">Define the global settings for this specific event.</p>
                <form id="metaForm">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Camporee Title</label>
                            <input type="text" class="form-control" id="metaTitle"
                                placeholder="e.g. [District] Camporee 2026">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Theme</label>
                            <input type="text" class="form-control" id="metaTheme" placeholder="e.g. Space Odyssey">
                        </div>
                    </div>

                    <div class="accordion mt-3" id="accordionEventDetails">
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed fw-bold text-primary" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#collapseEventDetails">
                                    <i class="fas fa-calendar-alt fa-fw me-2"></i> Event Details
                                </button>
                            </h2>
                            <div id="collapseEventDetails" class="accordion-collapse collapse"
                                data-bs-parent="#accordionEventDetails">
                                <div class="accordion-body bg-light">
                                    <div class="row mb-3">
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold">Council</label>
                                            <input type="text" class="form-control" id="metaCouncil"
                                                placeholder="e.g. Cascade Pacific">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold">Location Name</label>
                                            <input type="text" class="form-control mb-1" id="metaLocName"
                                                placeholder="Camp Name">
                                            <input type="text" class="form-control form-control-sm" id="metaLocAddress"
                                                placeholder="Address">
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold">Start Date</label>
                                            <input type="date" class="form-control" id="metaStartDate">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold">End Date</label>
                                            <input type="date" class="form-control" id="metaEndDate">
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <label class="form-label fw-bold mb-0">Introduction</label>
                                            <div>
                                                <button type="button" class="btn btn-sm btn-outline-secondary me-1"
                                                    id="testAIBtn" onclick="composer.testAIKey()" title="Test API Key">
                                                    <i class="fas fa-key"></i>
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-primary"
                                                    onclick="composer.openBrainstormModal()">
                                                    <i class="fas fa-magic"></i> Brainstorm
                                                </button>
                                            </div>
                                        </div>
                                        <textarea id="metaIntroduction" class="form-control" rows="3"
                                            placeholder="Introduction markdown..."></textarea>
                                    </div>

                                    <div class="border rounded bg-white p-3">
                                        <h6 class="fw-bold mb-3"><i class="fas fa-address-book text-muted me-2"></i>Key
                                            Contacts</h6>
                                        <div id="contactsContainer"></div>
                                        <button type="button" class="btn btn-sm btn-outline-secondary mt-2 w-100"
                                            onclick="composer.addContact()">
                                            <i class="fas fa-plus"></i> Add Contact
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mt-4">
                        <div class="col-12 text-center">
                            <button type="button" class="btn btn-outline-primary"
                                onclick="window.bootstrap.Modal.getOrCreateInstance(document.getElementById('libraryModal')).show()">
                                <i class="fas fa-book"></i> Browse Library
                            </button>
                        </div>
                    </div>
                </form>
            </div>

            <div id="presets-pane" class="editor-pane d-none">
                <div id="presets-container"></div>
            </div>

            <div id="editor-pane" class="editor-pane d-none">
                <div id="editor-container">
                    <p class="text-muted">Select a game from the list to edit it.</p>
                </div>
            </div>

        </main>
    </div>

    <!-- Library Modal -->
    <div class="modal fade" id="libraryModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-light">
                    <h5 class="modal-title"><i class="fas fa-book"></i> Game Library</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <!-- Search Bar added for filtering -->
                <div class="p-2 border-bottom bg-light">
                    <input type="text" id="composer-catalog-search" class="form-control"
                        placeholder="Search titles or #tags..." onkeyup="composer.filterCatalog()">
                </div>
                <div class="modal-body p-0">
                    <ul id="library-list" class="list-unstyled p-0 mb-0"></ul>
                </div>
                <div class="modal-footer justify-content-between bg-light">
                    <div id="library-status" class="text-muted small">Loading Library...</div>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="previewModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable" id="previewModalDialog">
            <div class="modal-content">
                <div class="modal-header bg-light">
                    <h5 class="modal-title" id="previewModalTitle">Game Preview</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="previewModalBody">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary d-none" id="previewPrintBtn"
                        onclick="composer.printPreview()"><i class="fas fa-print"></i> Print</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- AI Brainstorm Modal -->
    <div class="modal fade" id="brainstormModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="fas fa-magic"></i> AI Theme Embellisher</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small">Select an introduction generated by AI based on your theme.</p>

                    <div id="brainstormLoading" class="text-center py-4 d-none">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mt-2 text-muted">Brainstorming with Gemini...</p>
                    </div>

                    <div id="brainstormResults" class="d-none">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="card h-100 border-primary">
                                    <div class="card-header bg-primary text-white fw-bold small"><i
                                            class="fas fa-bolt"></i> Action-Oriented</div>
                                    <div class="card-body small" id="bsOptionAction"></div>
                                    <div class="card-footer bg-transparent border-0 p-2">
                                        <button class="btn btn-sm btn-outline-primary w-100"
                                            onclick="composer.selectBrainstorm('action')">Select</button>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card h-100 border-success">
                                    <div class="card-header bg-success text-white fw-bold small"><i
                                            class="fas fa-book-journal-whills"></i> Lore-Heavy</div>
                                    <div class="card-body small" id="bsOptionLore"></div>
                                    <div class="card-footer bg-transparent border-0 p-2">
                                        <button class="btn btn-sm btn-outline-success w-100"
                                            onclick="composer.selectBrainstorm('lore')">Select</button>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card h-100 border-info">
                                    <div class="card-header bg-info text-white fw-bold small"><i
                                            class="fas fa-compass"></i> Skill-Focused</div>
                                    <div class="card-body small" id="bsOptionSkill"></div>
                                    <div class="card-footer bg-transparent border-0 p-2">
                                        <button class="btn btn-sm btn-outline-info w-100"
                                            onclick="composer.selectBrainstorm('skill')">Select</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top">
                        <label class="form-label small fw-bold">Not quite right? Refine the prompt:</label>
                        <div class="input-group">
                            <input type="text" class="form-control form-control-sm" id="brainstormRefineInput"
                                placeholder="e.g. Make it sound like a pirate captain...">
                            <button class="btn btn-sm btn-secondary" onclick="composer.runBrainstorm()"><i
                                    class="fas fa-sync-alt"></i> Try Again</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="themeModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title"><i class="fas fa-magic"></i> AI Theme Embellisher</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-secondary small mb-3">
                        <strong>Camporee Context:</strong> <span id="themeContextText"></span>
                    </div>

                    <div id="themeLoading" class="text-center py-5 d-none">
                        <div class="spinner-border text-info" role="status" style="width: 3rem; height: 3rem;">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <h5 class="mt-3 text-muted">Theming this game...</h5>
                        <p class="text-muted small">Gemini is rewriting the narrative to fit your camporee theme.</p>
                    </div>

                    <div id="themeResults" class="d-none">
                        <div class="row">
                            <div class="col-md-6 border-end">
                                <h6 class="fw-bold text-muted"><i class="fas fa-file-alt"></i> Original (Generic)</h6>
                                <div class="bg-light p-3 rounded small" style="max-height: 400px; overflow-y: auto;"
                                    id="themeOriginalPreview"></div>
                            </div>
                            <div class="col-md-6">
                                <h6 class="fw-bold text-info"><i class="fas fa-magic"></i> AI Draft (Themed)</h6>
                                <div class="bg-light p-3 rounded small border border-info"
                                    style="max-height: 400px; overflow-y: auto;" id="themeDraftPreview"></div>
                            </div>
                        </div>
                    </div>

                    <div id="themeInputArea" class="mt-4 pt-3 border-top">
                        <label class="form-label small fw-bold">Feedback / Directions for AI:</label>
                        <div class="input-group">
                            <input type="text" class="form-control" id="themeRefineInput"
                                placeholder="e.g. Make the story about discovering a hidden pirate map...">
                            <button class="btn btn-info text-white" id="themeGenerateBtn"
                                onclick="composer.runThemeGame()"><i class="fas fa-bolt"></i> Generate Draft</button>
                        </div>
                    </div>

                </div>
                <div class="modal-footer justify-content-between bg-light">
                    <button type="button" class="btn btn-outline-danger d-none" id="themeRevertBtn"
                        onclick="composer.revertTheme()"><i class="fas fa-undo"></i> Revert to Generic</button>
                    <div>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary d-none" id="themeCommitBtn"
                            onclick="composer.commitTheme()"><i class="fas fa-check"></i> Commit to Cartridge</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.5/FileSaver.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/handlebars@latest/dist/handlebars.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/easymde/dist/easymde.min.css">
    <script src="https://unpkg.com/easymde/dist/easymde.min.js"></script>

    <script type="module" src="/js/apps/composer.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const resizer = document.getElementById('sidebar-resizer');
            const sidebar = document.getElementById('composer-sidebar');
            let isResizing = false;

            if (resizer && sidebar) {
                resizer.addEventListener('mousedown', function (e) {
                    isResizing = true;
                    resizer.classList.add('resizing');
                    document.body.style.cursor = 'col-resize';
                    document.body.style.userSelect = 'none'; // Prevent text selection while dragging
                    e.preventDefault();
                });

                document.addEventListener('mousemove', function (e) {
                    if (!isResizing) return;

                    // Constrain width between 250px and 800px
                    let newWidth = e.clientX;
                    if (newWidth < 250) newWidth = 250;
                    if (newWidth > 800) newWidth = 800;

                    sidebar.style.width = newWidth + 'px';
                });

                document.addEventListener('mouseup', function () {
                    if (isResizing) {
                        isResizing = false;
                        resizer.classList.remove('resizing');
                        document.body.style.cursor = 'default';
                        document.body.style.userSelect = 'auto';
                    }
                });
            }
        });
    </script>
</body>

</html>